  _ScreenMetadata _getScreenMetadata(int index) {
    // 1. Check custom titles first
    final customTitle = widget.config.extraScreenTitles[index];
    if (customTitle != null && customTitle.isNotEmpty) {
      // Check if mapped to a parent
      final parentIndex = widget.config.screenParentMapping[index];
      String? parentTitle;

      if (parentIndex != null) {
        // Find parent title
        for (final item in widget.config.navigationItems) {
          if (item.index == parentIndex) {
            parentTitle = item.title;
            break;
          }
        }
      }
      return _ScreenMetadata(title: customTitle, parentTitle: parentTitle);
    }

    // 2. Search in navigation items
    for (final item in widget.config.navigationItems) {
      if (item.index == index) {
        return _ScreenMetadata(title: item.title, parentTitle: "Menu");
      }
      if (item.children != null) {
        for (final child in item.children!) {
          if (child.index == index) {
            return _ScreenMetadata(title: child.title, parentTitle: item.title);
          }
        }
      }
    }

    return _ScreenMetadata(title: 'Unknown Screen', parentTitle: null);
  }

  Widget _buildHeaderAction(IconData icon, {bool hasBadge = false}) {
    return Container(
      width: 40,
      height: 40,
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: const Color(0xFFE2E8F0), // Slate 200
        ),
      ),
      child: Material(
        color: Colors.transparent,
        child: InkWell(
          onTap: () {},
          borderRadius: BorderRadius.circular(12),
          hoverColor: const Color(0xFFF1F5F9), // Slate 50
          child: Stack(
            alignment: Alignment.center,
            children: [
              Icon(
                icon,
                color: const Color(0xFF64748B), // Slate 500
                size: 22,
              ),
              if (hasBadge)
                Positioned(
                  top: 10,
                  right: 12,
                  child: Container(
                    width: 8,
                    height: 8,
                    decoration: BoxDecoration(
                      color: const Color(0xFFEF4444), // Red 500
                      shape: BoxShape.circle,
                      border: Border.all(color: Colors.white, width: 1.5),
                    ),
                  ),
                ),
            ],
          ),
        ),
      ),
    );
  }
}

class _ScreenMetadata {
  final String title;
  final String? parentTitle;

  _ScreenMetadata({required this.title, this.parentTitle});
}
